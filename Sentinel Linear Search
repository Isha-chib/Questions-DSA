#include <stdio.h>

int sentinelLinearSearch(int arr[], int n, int key)
{
    int last = arr[n-1];
    arr[n-1] = key;

    int i = 0;

    while(arr[i] != key)
        i++;

    arr[n-1] = last;

    if(i < n-1 || last == key)
        return i;

    return -1;
}

int main()
{
    int arr[] = {12,45,23,67,89,34,90};
    int n = sizeof(arr)/sizeof(arr[0]);
    int key = 34;

    int index = sentinelLinearSearch(arr,n,key);

    if(index != -1)
        printf("Found at index %d",index);
    else
        printf("Not Found");

    return 0;
}
